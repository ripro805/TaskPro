# =========================================================
# TaskPro - environment template
# Copy this file to ".env" for local dev, OR paste the
# values into Vercel -> Project Settings -> Environment
# Variables for production.
# =========================================================

# ----- Django core -----
# Generate a fresh value with:
#   python -c "import secrets; print(secrets.token_urlsafe(60))"
SECRET_KEY=django-insecure-CHANGE-ME-before-deploy

# Local dev = True, production (Vercel) = False
DJANGO_DEBUG=True

# Comma-separated. For Vercel preview use *.vercel.app;
# add your custom domain when ready.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,testserver

# ----- Database (Neon PostgreSQL) -----
# Example:
#   postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=

# ----- Email (optional, used for password reset / activation) -----
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
# Use a Gmail App Password if 2FA is enabled.
EMAIL_HOST_PASSWORD=

# ----- App -----
FRONTEND_URL=http://127.0.0.1:8000
